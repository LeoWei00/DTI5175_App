<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Food Image -->
        <ImageView
            android:id="@+id/foodDetailImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"
            android:layout_marginBottom="16dp" />

        <!-- Food Name -->
        <TextView
            android:id="@+id/foodDetailName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Food Name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="8dp" />

        <!-- Posted By -->
        <TextView
            android:id="@+id/postedByUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Posted by: Username"
            android:textSize="16sp"
            android:textColor="#555555"
            android:layout_marginBottom="8dp" />

        <!-- Category -->
        <TextView
            android:id="@+id/foodDetailCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category: "
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/foodDetailDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description here..."
            android:textSize="14sp"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <!-- Quantity -->
        <TextView
            android:id="@+id/foodDetailQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quantity: "
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <!-- Allergens -->
        <TextView
            android:id="@+id/foodDetailAllergens"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Allergens: None"
            android:textSize="14sp"
            android:textColor="#D32F2F"
            android:layout_marginBottom="8dp" />

        <!-- Dietary Tags -->
        <TextView
            android:id="@+id/foodDetailDiets"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Diet: "
            android:textSize="14sp"
            android:textColor="#388E3C"
            android:layout_marginBottom="8dp" />

        <!-- Pickup Location -->
        <TextView
            android:id="@+id/foodDetailLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Location: "
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <!-- Pickup Date & Time -->
        <TextView
            android:id="@+id/foodDetailPickupTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pickup: "
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Type: Donate or Sell -->
        <TextView
            android:id="@+id/foodDetailType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type: Donate"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_marginBottom="24dp" />

        <!-- View on Map Button -->
        <Button
            android:id="@+id/viewOnMapButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View on Map"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp" />

        <!-- Get Directions Button -->
        <Button
            android:id="@+id/getDirectionsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Get Directions"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
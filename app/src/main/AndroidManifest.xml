<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- GPS Permission -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <!-- Camera permission -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SharEat">
        <activity
            android:name=".MessagesActivity"
            android:exported="false"
            android:label="@string/title_activity_messages"
            android:theme="@style/Theme.SharEat" />

        <activity
            android:name=".MyPostsActivity"
            android:exported="false"
            android:label="@string/title_activity_my_posts"
            android:theme="@style/Theme.SharEat" />
        <activity
            android:name=".MyReservationsActivity"
            android:exported="false"
            android:label="@string/title_activity_my_reservations"
            android:theme="@style/Theme.SharEat" />
        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:label="@string/title_activity_profile"
            android:theme="@style/Theme.SharEat" />
        <activity android:name=".FoodDetailActivity" />
        <activity android:name=".HomeActivity" />
        <activity
            android:name=".PostFoodActivity"
            android:exported="false" />
        <activity android:name=".LoginActivity" />
        <activity
            android:name=".AuthActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ChatActivity"
            android:exported="false" />
    </application>

</manifest>
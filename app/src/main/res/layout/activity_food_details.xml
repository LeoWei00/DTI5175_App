<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAF8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/foodDetailImage"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:scaleType="centerCrop"
            android:src="@drawable/shareat_placeholder" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/foodDetailName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pasta Carbonara"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#1E2B27" />

                <TextView
                    android:id="@+id/foodDetailType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Donate"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/badge_background"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/postedByUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Posted by: John Doe"
                android:textSize="14sp"
                android:textColor="#63706C"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/foodDetailCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category: Italian"
                android:textSize="14sp"
                android:textColor="#23C483"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/foodDetailDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fresh homemade pasta with creamy sauce"
                android:textSize="15sp"
                android:textColor="#424242"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/info_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🍽️"
                        android:textSize="20sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quantity"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#424242"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/foodDetailQuantity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 servings"
                        android:textSize="14sp"
                        android:textColor="#616161" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️"
                        android:textSize="20sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Allergens"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#D32F2F"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/foodDetailAllergens"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dairy, Gluten, Eggs"
                        android:textSize="14sp"
                        android:textColor="#D32F2F" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥗"
                        android:textSize="20sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dietary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#388E3C"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/foodDetailDiets"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vegetarian"
                        android:textSize="14sp"
                        android:textColor="#388E3C" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/info_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍"
                        android:textSize="20sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/foodDetailLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="123 Main Street, Toronto"
                        android:textSize="14sp"
                        android:textColor="#424242" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕐"
                        android:textSize="20sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/foodDetailPickupTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jan 20, 10:00 AM - 2:00 PM"
                        android:textSize="14sp"
                        android:textColor="#424242" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/viewOnMapButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="📍  View on Map"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_green"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/getDirectionsButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="🧭  Get Directions"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_green"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/chatButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="✉️ Message"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#23C483"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/callButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="📞 Call"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF8A3D"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/smsButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="✉️ SMS"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#607D8B"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <Button
                android:id="@+id/reserveButton"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="🍽️  Reserve This Meal"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#23C483"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
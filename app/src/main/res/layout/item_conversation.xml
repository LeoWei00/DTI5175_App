<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/tvConversationName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sarah Chen"
            android:textColor="#1E2B27"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvConversationPostTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="About: Homemade Pasta"
            android:textColor="#23C483"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvConversationLastMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Hi! Is this still available?"
            android:textColor="#63706C"
            android:textSize="14sp"
            android:maxLines="2" />

    </LinearLayout>

</androidx.cardview.widget.CardView>